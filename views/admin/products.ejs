            <div class="main-panel">
                <div class="content-wrapper">
                    <div class="col-lg-12 stretch-card">
                        <div class="card">
                            <div class="card-body">
                                </p>
                                <div class="table-responsive">
                                    <table class="table table-bordered table-contextual" id="example">
                                        <thead>
                                            <tr>
                                                <th>Image</th>
                                                <th>Product Name</th>
                                                <th>Quantity</th>
                                                <th>Price</th>
                                                <th>Brand</th>
                                                <th>Status</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <%if(products.length>0){%>
                                                <%for(let i=0;i<products.length;i++){%>
                                                    <tr>
                                                        <td>
                                                            <img src="/myImages/<%= products[i].image[0] %>" alt="">
                                                        </td>
                                                        <td>
                                                            <%= products[i].name %>
                                                        </td>
                                                        <td>
                                                            <%= products[i].quantity %>
                                                        </td>
                                                        <td>
                                                            <%= products[i].price %>
                                                        </td>
                                                        <td>
                                                            <%= products[i].brand %>
                                                        </td>
                                                        <td>
                                                            <span>
                                                                <% if(products[i].is_listed){ %>
                                                                    <span id="status_<%=products[i]._id%>"
                                                                        class="badge rounded-pill alert-warning">Unlisted</span>
                                                                    <% } else { %>
                                                                        <span id="status_<%=products[i]._id%>"
                                                                            class="badge rounded-pill alert-warning">Listed</span>
                                                                        <% } %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-inverse-danger   unlist-product"
                                                                data-product-id="<%= products[i]._id %>">Unlist</button>
                                                            <button class="btn btn-inverse-success  list-product"
                                                                data-product-id="<%= products[i]._id %>">List</button>
                                                            <button class="btn btn-inverse-primary"><a
                                                                    href="/admin/editProduct?productId=<%= products[i]._id %>">Edit</a></button>
                                                        </td>
                                                    </tr>
                                                    <%}%>
                                                        <%}else{%>
                                                            <tr>
                                                                <td colspan="5">Products not found</td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
